# 云上部署 env 模板（配合 docker-compose.cloud.yml）。复制为 .env.cloud 后填写：
#   docker compose -f docker-compose.yml -f docker-compose.cloud.yml --env-file .env.cloud up -d --build
# 敏感项（密钥）勿提交仓库。完整变量说明见 .env.example；这里只列云上需要显式设置的项。

# ---- 域名 / 入站 ------------------------------------------------------------
# Caddy 用 DOMAIN 自动申请 Let's Encrypt 证书；域名 A 记录必须指向实例 EIP。
DOMAIN=unity-compare.example.com
# 对外访问本服务的基础地址（https）。决定飞书 OAuth 回调 {PUBLIC_BASE_URL}/auth/callback；
# 飞书开放平台「安全设置 → 重定向 URL」须逐字登记该回调地址。
PUBLIC_BASE_URL=https://unity-compare.example.com
# 云上把 compare-api 发布到宿主机 8080，仅供实例内排障 curl（安全组不放行 8080，公网走 Caddy 443）。
HOST_PORT=8080

# ---- 鉴权（公网必开）--------------------------------------------------------
AUTH_ENABLED=true
AUTH_API_KEY_ENABLED=true
# 飞书自建应用 App ID / App Secret（管理后台单管理员 OAuth 登录用；第一个登录者即管理员）。
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx

# ---- Android Package Service ------------------------------------------------
# 包下载走 APS（云上部署的 APS 域名），API Key 在 APS 的 /admin 创建。
APS_BASE_URL=https://android-packages.example.com
APS_API_KEY=xxxxx

# ---- 报告存储（AWS S3）------------------------------------------------------
# 同一个桶也承载 Litestream 的 SQLite 灾备（litestream/ 前缀，与报告前缀分开）。
# 推荐：给实例挂 IAM 角色（S3 读写权限），ACCESS_KEY 留空即走实例角色；
#       容器要能访问 IMDS —— 实例 metadata hop-limit 须设为 2（见部署文档）。
REPORT_STORAGE_BACKEND=s3
REPORT_S3_BUCKET=unity-compare-prod
REPORT_S3_REGION=us-west-2
REPORT_S3_ACCESS_KEY_ID=
REPORT_S3_SECRET_ACCESS_KEY=

# ---- AI 分析 -----------------------------------------------------------------
# OPENAI_BASE_URL 的接口按来源 IP 白名单放行：把实例的 EIP 提供给接口方登记。
# 出口 IP 验证：实例上 curl -s https://checkip.amazonaws.com 应返回 EIP。
OPENAI_API_KEY=xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1

# ---- 并发 / 清理（按机型调，见部署文档「容量与机型」）------------------------
TASK_CONCURRENCY=2
DOWNLOAD_CONCURRENCY=4
DUMP_CONCURRENCY=2
COMPARE_CONCURRENCY=2
KEEP_FAILED_WORK_DIR=false
WORK_DIR_TTL_HOURS=24
